{
  "compilerOptions": {
    "target": "esnext",  
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist"

  },
  "include": ["src"]
}